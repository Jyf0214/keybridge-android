<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/keyboard_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent">

    <!-- 浮动键盘卡片：CardView 自动裁剪子 View 到圆角轮廓 -->
    <androidx.cardview.widget.CardView
        android:id="@+id/keyboard_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        app:cardCornerRadius="16dp"
        app:cardBackgroundColor="#F1F3F4"
        app:cardElevation="4dp"
        app:cardUseCompatPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="4dp">

        <!-- 工具栏：修饰键状态 + 方向键切换 -->
        <LinearLayout
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="36dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="6dp"
            android:paddingEnd="4dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp"
            android:background="#E8EAED">

            <!-- 修饰键状态：用 FlowLayout 概念，自动换行 -->
            <LinearLayout
                android:id="@+id/mod_status_container"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/mod_shift"
                    android:layout_width="wrap_content"
                    android:layout_height="22dp"
                    android:gravity="center"
                    android:text="Shift"
                    android:textSize="10sp"
                    android:textColor="#FFFFFF"
                    android:paddingStart="5dp"
                    android:paddingEnd="5dp"
                    android:background="#1A73E8"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/mod_ctrl"
                    android:layout_width="wrap_content"
                    android:layout_height="22dp"
                    android:gravity="center"
                    android:text="Ctrl"
                    android:textSize="10sp"
                    android:textColor="#FFFFFF"
                    android:paddingStart="5dp"
                    android:paddingEnd="5dp"
                    android:background="#1A73E8"
                    android:layout_marginStart="3dp"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/mod_alt"
                    android:layout_width="wrap_content"
                    android:layout_height="22dp"
                    android:gravity="center"
                    android:text="Alt"
                    android:textSize="10sp"
                    android:textColor="#FFFFFF"
                    android:paddingStart="5dp"
                    android:paddingEnd="5dp"
                    android:background="#1A73E8"
                    android:layout_marginStart="3dp"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/mod_meta"
                    android:layout_width="wrap_content"
                    android:layout_height="22dp"
                    android:gravity="center"
                    android:text="Meta"
                    android:textSize="10sp"
                    android:textColor="#FFFFFF"
                    android:paddingStart="5dp"
                    android:paddingEnd="5dp"
                    android:background="#1A73E8"
                    android:layout_marginStart="3dp"
                    android:visibility="gone" />
            </LinearLayout>

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <!-- 方向键切换按钮 -->
            <ImageView
                android:id="@+id/btn_nav_toggle"
                android:layout_width="34dp"
                android:layout_height="30dp"
                android:padding="5dp"
                android:src="@drawable/ic_nav_toggle"
                android:background="@drawable/bg_nav_action"
                android:contentDescription="切换导航页面" />

            <!-- 收起键盘按钮 -->
            <ImageView
                android:id="@+id/btn_collapse"
                android:layout_width="34dp"
                android:layout_height="30dp"
                android:padding="5dp"
                android:src="@drawable/ic_chevron_down_simple"
                android:background="@drawable/bg_nav_action"
                android:contentDescription="收起键盘"
                android:layout_marginStart="2dp" />
        </LinearLayout>

        <!-- 键盘内容区域（普通键盘） -->
        <io.github.jyf0214.keybridge.ime.KeyboardView
            android:id="@+id/keyboard_view"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <!-- 导航页面（方向键+编辑操作，默认隐藏） -->
        <include
            android:id="@+id/nav_page"
            layout="@layout/keyboard_nav_page"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

</FrameLayout>
